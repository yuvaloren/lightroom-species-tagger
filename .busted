-- busted configuration. Run with `busted` (or `just test`) from the repo root.
return {
	_all = {
		-- src/shared/ for the plugin modules; output/deps/ for the pulled dkjson
		-- (run `just deps` or `lua build/build.lua --fetch-deps` first); spec/ so
		-- `require 'support.fixtures'` etc. resolve.
		lpath = './?.lua;./?/init.lua;src/shared/?.lua;output/deps/?.lua;spec/?.lua',
	},
	default = {
		ROOT = { 'spec' },
		pattern = '_spec%.lua$',
	},
}
