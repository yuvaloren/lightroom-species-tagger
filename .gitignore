# ─────────────────────────────────────────────────────────────────────────────
# Nothing generated or third-party is committed. Everything below is reproducible
# from source (see the "Repository layout" section of README.md). If you're asking
# "is all that code in output/ ours?" — no: those are the trees here.
# ─────────────────────────────────────────────────────────────────────────────

# GENERATED — the ONE output tree. Removed by `just clean`. Holds:
#   output/dist/  the composed .lrplugin bundle + zips (build/build.lua from src/)
#   output/deps/  the one pulled Lua runtime dep (dkjson), fetched via LuaRocks
/output/

# GENERATED — the Go helper's cross-compiled binaries (build/build.lua, or
# `just build`, produces these). Removed by `just clean`.
/src/helper/dist/

# TOOLCHAIN (pinned) — the isolated Lua 5.1 + LuaRocks env created by `just setup`.
# Not "output"; it's your installed dev env. `just clean-all` removes it.
/.lua-env/

# LOCAL signing config sourced by build/release.sh (Developer ID identity + notary refs).
# Never commit — it's per-machine and references your signing setup.
/build/signing.env

# LOCAL ZXP signing material for the Adobe Exchange package (build/build-exchange.sh):
# self-signed cert + its generated password. Reused across versions; never commit.
/build/exchange-cert.p12
/build/exchange-cert.pass

# Test coverage artifacts.
luacov.stats.out
luacov.report.out

# Transient rename target used by `just clean` (removed at the end of the recipe).
/.output-trash-*

# ─────────────────────────────────────────────────────────────────────────────
# Never-commit user data. No image with personal metadata (EXIF / GPS / camera
# serial) belongs in the tree. The only committed images are DELIBERATELY
# metadata-stripped fixtures: the burst-accuracy corpus in
# test/plugin/fixtures/burst-corpus/ and the imghash fixtures in
# src/helper/imghash/testdata/. This guard keeps a stray personal photo from
# being committed by accident.
# ─────────────────────────────────────────────────────────────────────────────
test/**/*.jpg
test/**/*.jpeg
test/**/*.png
# Exception: the burst-detection accuracy corpus is a DELIBERATE, committed
# fixture (build/burst-accuracy.lua gates CI on it). These are 256 px frames
# with ALL metadata markers stripped — no EXIF, no GPS, no camera serial (see
# the strip step in that commit) — so the guard's intent still holds.
!test/plugin/fixtures/burst-corpus/*.jpg

# macOS
.DS_Store
