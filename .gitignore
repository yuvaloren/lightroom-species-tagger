# Build output + pulled dependencies (never committed; pulled at build time)
/dist/
/build/.deps/

# Pinned local Lua toolchain (created by scripts/dev-setup.sh)
/.lua-env/

# Test coverage artifacts
luacov.stats.out
luacov.report.out

# Live test images are the user's own photos — never committed. Drop originals
# into spec/fixtures/images/ to enable live recording / live accuracy runs.
/spec/fixtures/images/*
!/spec/fixtures/images/.gitkeep
!/spec/fixtures/images/README.md

# Raw Google Lens HTML dumped by `build-corpus.lua --live` (for auditing the
# captures) — large and may carry transient session tokens; never committed.
/spec/fixtures/lens/raw/

# Your browser's "Copy as cURL" for live Lens capture — contains your cookies.
/spec/fixtures/.lens-session.curl

# macOS
.DS_Store
