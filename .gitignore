# ─────────────────────────────────────────────────────────────────────────────
# Nothing generated or third-party is committed. Everything below is reproducible
# from source (see the "Repository layout" section of README.md). If you're asking
# "is all that code in output/ / node_modules ours?" — no: those are the trees here.
# ─────────────────────────────────────────────────────────────────────────────

# GENERATED — the ONE output tree. Removed by `just clean`. Holds:
#   output/dist/  the composed .lrplugin bundle + zips (build/build.lua from src/)
#   output/deps/  the one pulled Lua runtime dep (dkjson), fetched via LuaRocks
/output/

# THIRD-PARTY (pulled) — Node deps for the Google Lens browser helper (puppeteer-core),
# installed with `npm ci` in scripts/lens. Pure JS; not ours. It can't live under
# output/ because Node resolves modules next to package.json. (package-lock.json IS
# committed, so installs are reproducible and CI can bundle it into the release.)
/scripts/lens/node_modules/

# TOOLCHAIN (pinned) — the isolated Lua 5.1 + LuaRocks env created by ./dev-setup.sh.
# Not "output"; it's your installed dev env. `just clean-all` removes it.
/.lua-env/

# LOCAL signing config sourced by release.sh (Developer ID identity + notary profile refs).
# Never commit — it's per-machine and references your signing setup.
/scripts/signing.env

# Test coverage artifacts.
luacov.stats.out
luacov.report.out

# Transient rename target used by `just clean` (removed at the end of the recipe).
/.output-trash-*

# ─────────────────────────────────────────────────────────────────────────────
# Never-commit user data. The automated suite uses NO real photos: unit tests replay
# the committed GBIF JSON in spec/fixtures/gbif/, and the Lens-helper integration test
# generates a throwaway JPEG at run time. So no image belongs in the tree — this guard
# keeps a stray photo (personal EXIF / GPS) from being committed by accident.
# ─────────────────────────────────────────────────────────────────────────────
spec/**/*.jpg
spec/**/*.jpeg
spec/**/*.png

# macOS
.DS_Store
