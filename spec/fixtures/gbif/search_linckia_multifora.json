266118,"scientificName":"Linckia multifora Lamarck, 1816","canonicalName":"Linckia multifora","authorship":"Lamarck, 1816","nameType":"SCIENTIFIC","taxonomicStatus":"ACCEPTED","rank":"SPECIES","origin":"SOURCE","numDescendants":0,"numOccurrences":0,"taxonID":"17856","habitats":[],"nomenclaturalStatus":[],"threatStatuses":[],"descriptions":[],"vernacularNames":[],"synonym":false,"higherClassificationMap":{"157533281":"Animalia","216257622":"Echinodermata","216264084":"Asteroidea","216265589":"Valvatida","216266051":"Ophidiasteridae","216266088":"Linckia"},"class":"Asteroidea"},{"key":5187112,"nameKey":6347997,"datasetKey":"d7dddbf4-2cf0-4f39-9b2a-bb099caae36c","constituentKey":"7ddf754f-d193-4cc9-b351-99906754a03b","nubKey":5187112,"parentKey":5187090,"parent":"Linckia","basionymKey":5818337,"basionym":"Asterias multifora Lamarck, 1816","kingdom":"Animalia","phylum":"Echinodermata","order":"Valvatida","family":"Ophidiasteridae","genus":"Linckia","species":"Linckia multifora","kingdomKey":1,"phylumKey":50,"classKey":214,"orderKey":810,"familyKey":5779,"genusKey":5187090,"speciesKey":5187112,"scientificName":"Linckia multifora (Lamarck, 1816)","canonicalName":"Linckia multifora","authorship":"(Lamarck, 1816) ","publishedIn":"World Asteroidea Database. Linckia multifora (Lamarck, 1816). Accessed through: World Register of Marine Species at: http://www.marinespecies.org/aphia.php?p=taxdetails&id=207607 on 2020-02-17","nameType":"SCIENTIFIC","taxonomicStatus":"ACCEPTED","rank":"SPECIES","origin":"SOURCE","numDescendants":0,"numOccurrences":0,"taxonID":"gbif:5187112","extinct":false,"habitats":["MARINE"],"nomenclaturalStatus":[],"threatStatuses":[],"descriptions":[{"description":"Material examined: 6 specimens (ZMSBUK- 1643 / 1 - ZMSBUK- 1643 / 6) Largest sampled specimen in this study: R: 153 mm, r: 13 mm."},{"description":"Observations: Found on hard substrates, occasionally amongst shells, gravels, dead - corals, or on coralreefs; from 2 m to 13 m; Recorded in the present study from Hengam, Qeshm, Larak, Lavan, Kish, Kharg and Kharku Islands. Observed subtidally at Bostaneh. Previously reported from the Persian Gulf: (Mortensen 1940; Clark & Rowe 1971; Basson et al. 1977; Price 1982 a; Price 1982 b; Price 1983; Khayat 2005; George 2012; Adeli et al. 2022); present study."},{"description":"Description: (Figs. 25 – 28) Five (occasionally four to six) long thin arms and small disc (R / r:> 10: 1), arms typically unequal and cylindrical, almost completely circular in cross-section; plates of abactinal surface with irregularly spaced mix of numerous, flat granules and closed pores; no obvious gonopores; two madreporites typical; no distinctive supero-marginal or infero-marginal plates defining body margin; plates on actinal surface covered by dense, small granules; ambulacral plates with conspicuous protruded edge; subambulacral spines rounded and granule like, separated and barely projecting from the plate surface, surrounded by many smaller granules; tube feet cylindrical with terminal disc; colour in live specimens usually khaki or red with brownish-yellow and / or purplish-red arm spots, colour completely bleaches in alcohol."},{"description":"MATERIAL EXAMINED. — MHNH; Lesueur drawings collection; ref. 74019; Baudin expedition; Péron and Lesueur leg."},{"description":"DISTRIBUTION. — The species commonly occurs in the whole Indo-West Pacific. It does not occur in European seas contrary to Lamarck’s assumption."},{"description":"REMARK Lamarck’s type material could not be found in MNHN."},{"description":"(Fig. 21)"},{"description":"REMARK Original drawings of A. multifora are presented in Jangoux (2021: 232 fig. 21)."}],"vernacularNames":[{"vernacularName":"多篩指海星","language":"zho"},{"vernacularName":"ดาวแดง","language":"tha"},{"vernacularName":"Estrela-coralina-pintada","language":"por"},{"vernacularName":"ゴマフヒトデ／ウスイロホウキボシ","language":"jpn"},{"vernacularName":"ゴマフヒトデ","language":"jpn"},{"vernacularName":"Stella cometa indo-pacifica","language":"ita"},{"vernacularName":"Comète de mer","language":"fra"},{"vernacularName":"Spotted Linckia","language":"eng"},{"vernacularName":"Multipore Sea Star","language":"eng"},{"vernacularName":"Löchriger Seestern","language":"deu"},{"vernacularName":"Kometenstern","language":"deu"},{"vernacularName":"hvězdice kometová","language":"ces"},{"vernacularName":"ゴマフヒトデ／ウスイロホウキボシ","language":"jpn"},{"vernacularName":"ゴマフヒトデ／ウスイロホウキボシ","language":"jpn"}],"synonym":false,"higherClassificationMap":{"1":"Animalia","50":"Echinodermata","214":"Asteroidea","810":"Valvatida","5779":"Ophidiasteridae","5187090":"Linckia"},"class":"Asteroidea"},{"key":273152134,"datasetKey":"e007cc4a-8704-449d-8829-bb209d26d6c8","nubKey":5187112,"parentKey":273152014,"parent":"Linckia","kingdom":"Animalia","phylum":"Echinodermata","family":"Ophidiasteridae","genus":"Linckia","species":"Linckia multifora","kingdomKey":270195436,"phylumKey":273076691,"classKey":300768338,"familyKey":300768709,"genusKey":273152014,"speciesKey":273152134,"scientificName":"Linckia multifora (Lamarck, 1816)","canonicalName":"Linckia multifora","authorship":"(Lamarck, 1816)","nameType":"SCIENTIFIC","taxonomicStatus":"ACCEPTED","rank":"SPECIES","origin":"SOURCE","numDescendants":0,"numOccurrences":0,"taxonID":"6QGC9","extinct":false,"habitats":["MARINE"],"nomenclaturalStatus":[],"threatStatuses":[],"descriptions":[],"vernacularNames":[{"vernacularName":"ゴマフヒトデ／ウスイロホウキボシ","language":"jpn"}],"synonym":false,"higherClassificationMap":{"270195436":"Animalia","273076691":"Echinodermata","300768338":"Asteroidea","300768709":"Ophidiasteridae","273152014":"Linckia"},"class":"Asteroidea"}],"facets":[]}