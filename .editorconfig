# EditorConfig — consistent whitespace across editors. https://editorconfig.org
# Matches the conventions in CONTRIBUTING.md so a newcomer's editor does the right
# thing without being told twice.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Lua is tab-indented (see CONTRIBUTING.md → Conventions). luacheck enforces the rest.
[*.lua]
indent_style = tab

# The Node Lens helper and all config/data files are 2-space.
[*.{js,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
# Markdown uses trailing spaces for hard line breaks — don't strip them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
